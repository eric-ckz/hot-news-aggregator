  "devDependencies": {
    "@vitejs/plugin-vue": "^4.5.2",
    "@vue/tsconfig": "^0.5.1",
    "typescript": "~5.3.0",
    "vite": "^5.0.10",
    "vue-tsc": "^1.8.25",
    "@types/node": "^20.10.5",
    "eslint": "^8.56.0",
    "@vue/eslint-config-typescript": "^12.0.0",
    "sass": "^1.69.5"
